# EdgeAgent — Environment Variables
# Bu dosyayi .env olarak kopyalayip duzenlein.

# GPU
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Uygulama
EDGEAGENT_CONFIG=configs/production_config.yaml
EDGEAGENT_LOG_LEVEL=INFO
EDGEAGENT_MODE=inference    # inference | training | dev

# MQTT (opsiyonel)
MQTT_BROKER=localhost
MQTT_PORT=1883

# OPC-UA (opsiyonel)
OPCUA_ENDPOINT=opc.tcp://0.0.0.0:4840/edgeagent
